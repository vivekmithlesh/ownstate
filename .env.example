# OwnState — environment variables.
# Copy to .env.local and fill in real values. NEVER commit .env.local.

# --- Supabase ---------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-only — never exposed to the browser
DATABASE_URL=postgresql://...pooled...
DIRECT_URL=postgresql://...direct...

# --- Razorpay (Test Mode) ---------------------------------------------------
RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxx

# --- App --------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000   # set to the live URL in production
