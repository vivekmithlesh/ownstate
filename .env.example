# OwnState — environment variables.
# Copy to .env.local and fill in real values. NEVER commit .env.local.

# --- Supabase ---------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-only — never exposed to the browser
DATABASE_URL=postgresql://...pooled...
DIRECT_URL=postgresql://...direct...

# --- Razorpay (Test Mode) ---------------------------------------------------
RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret            # server-only
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
# Razorpay Dashboard → Settings → Webhooks. Same value set there and here.
# Powers /api/payment/webhook (recovers payments when the browser closes).
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret # server-only

# --- Observability (optional; no-op if unset) -------------------------------
# Add a Sentry DSN to capture frontend + backend errors. See PRODUCTION.md.
# NEXT_PUBLIC_SENTRY_DSN=

# --- Bot protection (optional; see PRODUCTION.md) ---------------------------
# Cloudflare Turnstile keys for signup / login / enquiry protection.
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=

# --- App --------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000   # set to the live URL in production
